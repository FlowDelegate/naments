{
  "name": "@flowdelegate/naments",
  "version": "1.0.0",
  "description": "Themed name arrays for agents, bots, and fixtures. Pass a category, get fun names.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "new-category": "tsx scripts/new-category.ts"
  },
  "keywords": [
    "names",
    "agents",
    "themes",
    "random",
    "fun",
    "bots",
    "fixtures"
  ],
  "author": "FlowDelegate",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/FlowDelegate/naments.git"
  },
  "bugs": {
    "url": "https://github.com/FlowDelegate/naments/issues"
  },
  "homepage": "https://github.com/FlowDelegate/naments#readme",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  }
}
